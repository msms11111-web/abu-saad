{
  "name": "saudi-essence-backend",
  "version": "1.0.0",
  "description": "Backend for Saudi Essence E-Commerce Platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "node --loader ts-node/esm src/seed.ts",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "stripe": "^13.7.0",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.5.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "redis": "^4.6.11",
    "socket.io": "^4.7.2",
    "nodemailer": "^6.9.6",
    "uuid": "^9.0.0",
    "sharp": "^0.32.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.4",
    "ts-node": "^10.9.1",
    "vitest": "^0.34.6",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "eslint": "^8.51.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
