{
  "name": "saudi-essence-ecommerce",
  "version": "1.0.0",
  "description": "منصة عطور فاخرة سعودية - Saudi Essence E-Commerce Platform",
  "type": "module",
  "scripts": {
    "setup": "bash install.sh",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "build:docker": "docker build -t saudi-essence .",
    "start": "cd server && npm start",
    "seed": "cd server && npm run seed",
    "test": "concurrently \"npm run test:server\" \"npm run test:client\"",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "lint": "npm run lint:server && npm run lint:client",
    "lint:server": "cd server && npm run lint",
    "lint:client": "cd client && npm run lint",
    "clean": "rm -rf node_modules server/node_modules server/dist client/node_modules client/dist",
    "reinstall": "npm run clean && npm install"
  },
  "keywords": [
    "ecommerce",
    "saudi",
    "perfume",
    "عطور",
    "سعودي"
  ],
  "author": "Saudi Essence Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
