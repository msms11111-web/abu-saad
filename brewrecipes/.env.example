# ===========================================
# Brew Recipes - Environment Variables
# ===========================================
# المشروع يعمل حالياً بدون أي متغيرات بيئة (SQLite محلية + مصادقة تجريبية).
# المتغيرات أدناه تُستخدم عند الربط بالخدمات الحقيقية.

# Supabase (للمصادقة الحقيقية لاحقاً)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Prisma Database (عند الانتقال من SQLite إلى Postgres/Supabase
# غيّر provider في prisma/schema.prisma إلى postgresql واستخدم هذا الرابط)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# Stripe (للدفع - أضفه عند تفعيل الدفع)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
